<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:converters="clr-namespace:com.kizwiz.signwiz.Converters"
            xmlns:viewmodels="clr-namespace:com.kizwiz.signwiz.ViewModels"
            x:DataType="viewmodels:AchievementDetailsViewModel"
            x:Class="com.kizwiz.signwiz.Pages.AchievementDetailsPage"
            x:Name="thisPage"
            Style="{StaticResource AppPageStyle}"
            Title="Achievement Details">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <Grid Padding="20" RowDefinitions="Auto,Auto,Auto">
            <!-- Achievement Card (captured for sharing) -->
            <Border x:Name="AchievementCard"
                   StrokeThickness="2"
                   Stroke="#FFD700"
                   StrokeShape="RoundRectangle 24"
                   Padding="24"
                   Margin="0,10"
                   Shadow="{Shadow Brush=Black, Offset='4,6', Radius=20, Opacity=0.5}">
                <Border.Background>
                    <RadialGradientBrush Center="0.5,0.4" Radius="0.85">
                        <GradientStop Color="#1a237e" Offset="0.0"/>
                        <GradientStop Color="#0d1b5e" Offset="0.65"/>
                        <GradientStop Color="#1a1a3e" Offset="1.0"/>
                    </RadialGradientBrush>
                </Border.Background>

                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="16">
                    <!-- Glowing Icon Badge -->
                    <Border Grid.Row="0"
                           HeightRequest="120"
                           WidthRequest="120"
                           StrokeShape="RoundRectangle 60"
                           StrokeThickness="3"
                           Stroke="#FFD700"
                           BackgroundColor="#22FFD700"
                           HorizontalOptions="Center"
                           Shadow="{Shadow Brush=#FFD700, Offset='0,0', Radius=16, Opacity=0.4}">
                        <Image Source="{Binding Icon}"
                              HeightRequest="80"
                              WidthRequest="80"
                              HorizontalOptions="Center"
                              VerticalOptions="Center"/>
                    </Border>

                    <!-- Achievement Title -->
                    <Label Grid.Row="1"
                          Text="{Binding Title}"
                          TextColor="White"
                          FontSize="26"
                          FontAttributes="Bold"
                          HorizontalOptions="Center"
                          HorizontalTextAlignment="Center"/>

                    <!-- Achievement Description -->
                    <Label Grid.Row="2"
                          Text="{Binding Description}"
                          TextColor="#B0BEC5"
                          FontSize="16"
                          HorizontalOptions="Center"
                          HorizontalTextAlignment="Center"
                          Margin="8,0"/>

                    <!-- Progress Section -->
                    <VerticalStackLayout Grid.Row="3"
                                        IsVisible="{Binding IsUnlocked, Converter={StaticResource InverseBoolConverter}}"
                                        Spacing="6">
                        <Border StrokeShape="RoundRectangle 6"
                               BackgroundColor="#1A1A3E"
                               StrokeThickness="0"
                               HeightRequest="12"
                               Padding="0">
                            <ProgressBar Progress="{Binding Progress}"
                                        ProgressColor="#FFD700"
                                        HeightRequest="12"/>
                        </Border>
                        <Label Text="{Binding ProgressText}"
                              TextColor="#B0BEC5"
                              FontSize="14"
                              HorizontalOptions="Center"/>
                    </VerticalStackLayout>

                    <!-- Unlock Status -->
                    <HorizontalStackLayout Grid.Row="4"
                                 IsVisible="{Binding IsUnlocked}"
                                 HorizontalOptions="Center"
                                 Spacing="8">
                        <Label Text="🏆"
                               FontSize="22"
                               VerticalOptions="Center"/>
                        <Label Text="{Binding UnlockDateDisplay}"
                               TextColor="#FFD700"
                               FontSize="14"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>

                    <!-- SignWiz Watermark -->
                    <HorizontalStackLayout Grid.Row="5"
                                 HorizontalOptions="End"
                                 Opacity="0.5"
                                 Spacing="4"
                                 Margin="0,8,0,0">
                        <Label Text="🧙‍♂️"
                               FontSize="14"
                               VerticalOptions="Center"/>
                        <Label Text="SignWiz"
                               TextColor="#B0BEC5"
                               FontSize="12"
                               FontAttributes="Italic"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Grid>
            </Border>

            <!-- Share Button (outside the captured card) -->
            <Button Grid.Row="1"
                   Text="📸  SHARE ACHIEVEMENT"
                   IsVisible="{Binding IsUnlocked}"
                   Command="{Binding ShareCommand}"
                   BackgroundColor="#FFD700"
                   TextColor="#1a237e"
                   FontAttributes="Bold"
                   FontSize="16"
                   CornerRadius="16"
                   HeightRequest="52"
                   Margin="20,10,20,0"/>

            <!-- Your Collection Carousel -->
            <VerticalStackLayout Grid.Row="2" Spacing="8" Margin="0,24,0,10">
                <!-- Unlocked Count -->
                <Label Text="{Binding AchievementsCountText}"
                      TextColor="#FFD700"
                      FontSize="14"
                      FontAttributes="Bold"
                      HorizontalOptions="Center"/>

                <Label Text="Your Collection"
                      TextColor="White"
                      FontSize="18"
                      FontAttributes="Bold"
                      Margin="0,2,0,4"/>

                <CollectionView ItemsSource="{Binding AchievementCollection}"
                               HeightRequest="80"
                               SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="4"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:AchievementThumbnail">
                            <Border WidthRequest="64"
                                   HeightRequest="64"
                                   StrokeShape="RoundRectangle 14"
                                   BackgroundColor="#1A1A3E"
                                   Padding="10"
                                   StrokeThickness="2"
                                   Stroke="Transparent"
                                   Opacity="{Binding IsUnlocked, Converter={StaticResource BoolToOpacityConverter}}">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                Binding="{Binding IsSelected}"
                                                Value="True">
                                        <Setter Property="Stroke" Value="#FFD700"/>
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCollectionItemTapped"
                                                         NumberOfTapsRequired="1"/>
                                </Border.GestureRecognizers>
                                <Image Source="{Binding Icon}"
                                      HeightRequest="36"
                                      WidthRequest="36"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center"/>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>