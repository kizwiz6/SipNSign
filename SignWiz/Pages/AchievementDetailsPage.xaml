<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
            xmlns:converters="clr-namespace:com.kizwiz.signwiz.Converters"
            xmlns:viewmodels="clr-namespace:com.kizwiz.signwiz.ViewModels"
            x:DataType="viewmodels:AchievementDetailsViewModel"
            x:Class="com.kizwiz.signwiz.Pages.AchievementDetailsPage"
            x:Name="thisPage"
            Style="{StaticResource AppPageStyle}"
            Title="Achievement Details">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <Grid Padding="20" RowDefinitions="Auto,Auto,Auto">
            <!-- Share Container: Leonardo AI Background with Fixed Height -->
            <Border x:Name="ShareContainer"
                   Grid.Row="0"
                   StrokeThickness="0"
                   BackgroundColor="Transparent"
                   Padding="0"
                   Margin="0,10"
                   HeightRequest="500">
                <!-- Strong outer shadow for depth -->
                <Border.Shadow>
                    <Shadow Brush="#A0000000" Offset="0,10" Radius="25" Opacity="1.0"/>
                </Border.Shadow>

                <!-- Triple-Layer Border Frame -->
                <Border StrokeThickness="1" 
                       Stroke="#FFD700" 
                       StrokeShape="RoundRectangle 16" 
                       Padding="2">
                    <Border StrokeThickness="2" 
                           Stroke="#1a1a1a" 
                           StrokeShape="RoundRectangle 15" 
                           Padding="1">
                        <Border StrokeThickness="1" 
                               Stroke="#FFD700" 
                               StrokeShape="RoundRectangle 13">

                            <!-- Unified Layout with Starfield Background -->
                            <Grid RowDefinitions="Auto,*" RowSpacing="0">
                                <!-- Deep space gradient background -->
                                <BoxView Grid.RowSpan="2">
                                    <BoxView.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#0A0E27" Offset="0.0" />
                                            <GradientStop Color="#1B2768" Offset="0.4" />
                                            <GradientStop Color="#0D1B4E" Offset="0.8" />
                                            <GradientStop Color="#050A1F" Offset="1.0" />
                                        </LinearGradientBrush>
                                    </BoxView.Background>
                                </BoxView>

                                <!-- Centered Branding Header -->
                                <VerticalStackLayout Grid.Row="0"
                                                    HorizontalOptions="Center" 
                                                    VerticalOptions="Center" 
                                                    Spacing="4"
                                                    Padding="16"
                                                    HeightRequest="100">
                                    <!-- App Logo -->
                                    <Image Source="logo_nobg.png" 
                                           HeightRequest="80" 
                                           WidthRequest="80" 
                                           HorizontalOptions="Center"
                                           Aspect="AspectFit">
                                        <Image.Shadow>
                                            <Shadow Brush="#FFD700" Offset="0,0" Radius="14" Opacity="0.7"/>
                                        </Image.Shadow>
                                    </Image>

                                    <!-- SIGNWIZ Brand Text -->
                                    <Label Text="SIGNWIZ" 
                                           TextColor="#FFD700" 
                                           FontFamily="Bangers" 
                                           FontSize="30" 
                                           CharacterSpacing="4" 
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center">
                                        <Label.Shadow>
                                            <Shadow Brush="Black" Offset="0,2" Radius="14" Opacity="1.0"/>
                                        </Label.Shadow>
                                    </Label>
                                </VerticalStackLayout>

                                <!-- Achievement Content -->
                                <VerticalStackLayout Grid.Row="1" 
                                                    Padding="16,0,16,12" 
                                                    Spacing="12"
                                                    VerticalOptions="Center">

                                    <!-- Glowing Icon Badge -->
                                    <Grid HeightRequest="100" 
                                          WidthRequest="100"
                                          HorizontalOptions="Center">
                                        <!-- Outer Glow Layer -->
                                        <Border HeightRequest="100"
                                               WidthRequest="100"
                                               StrokeShape="RoundRectangle 50"
                                               StrokeThickness="0"
                                               BackgroundColor="Transparent">
                                            <Border.Shadow>
                                                <Shadow Brush="#FFD700" Offset="0,0" Radius="28" Opacity="0.5"/>
                                            </Border.Shadow>
                                        </Border>
                                        <!-- Medium Glow Layer -->
                                        <Border HeightRequest="90"
                                               WidthRequest="90"
                                               StrokeShape="RoundRectangle 45"
                                               StrokeThickness="0"
                                               BackgroundColor="Transparent"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                                            <Border.Shadow>
                                                <Shadow Brush="#FFD700" Offset="0,0" Radius="18" Opacity="0.7"/>
                                            </Border.Shadow>
                                        </Border>
                                        <!-- Inner Badge with Icon -->
                                        <Border HeightRequest="90"
                                               WidthRequest="90"
                                               StrokeShape="RoundRectangle 45"
                                               StrokeThickness="3"
                                               Stroke="#FFD700"
                                               BackgroundColor="#22FFD700"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center">
                                            <Border.Shadow>
                                                <Shadow Brush="#FFD700" Offset="0,0" Radius="10" Opacity="0.9"/>
                                            </Border.Shadow>
                                            <Image Source="{Binding Icon}"
                                                  HeightRequest="75"
                                                  WidthRequest="75"
                                                  HorizontalOptions="Center"
                                                  VerticalOptions="Center"
                                                  Aspect="AspectFill">
                                                <Image.Clip>
                                                    <EllipseGeometry Center="37.5,37.5" RadiusX="37.5" RadiusY="37.5"/>
                                                </Image.Clip>
                                            </Image>
                                        </Border>
                                    </Grid>

                                    <!-- Achievement Title -->
                                    <Label Text="{Binding Title}"
                                          TextColor="White"
                                          FontSize="22"
                                          FontAttributes="Bold"
                                          CharacterSpacing="1"
                                          HorizontalOptions="Center"
                                          HorizontalTextAlignment="Center">
                                        <Label.Shadow>
                                            <Shadow Brush="Black" Offset="0,3" Radius="12" Opacity="1.0"/>
                                        </Label.Shadow>
                                    </Label>

                                    <!-- Achievement Description -->
                                    <Label Text="{Binding Description}"
                                          TextColor="White"
                                          FontSize="15"
                                          HorizontalOptions="Center"
                                          HorizontalTextAlignment="Center"
                                          Margin="8,8,8,12">
                                        <Label.Shadow>
                                            <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="1.0"/>
                                        </Label.Shadow>
                                    </Label>

                                    <!-- Progress Section -->
                                    <VerticalStackLayout IsVisible="{Binding IsUnlocked, Converter={StaticResource InverseBoolConverter}}"
                                                        Spacing="6"
                                                        Margin="0,8,0,0">
                                        <Border StrokeShape="RoundRectangle 6"
                                               BackgroundColor="#1A1A3E"
                                               StrokeThickness="0"
                                               HeightRequest="12"
                                               Padding="0">
                                            <ProgressBar Progress="{Binding Progress}"
                                                        ProgressColor="#FFD700"
                                                        HeightRequest="12"/>
                                        </Border>
                                        <Label Text="{Binding ProgressText}"
                                              TextColor="White"
                                              FontSize="13"
                                              HorizontalOptions="Center">
                                            <Label.Shadow>
                                                <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="1.0"/>
                                            </Label.Shadow>
                                        </Label>
                                    </VerticalStackLayout>

                                    <!-- Unlock Status -->
                                    <HorizontalStackLayout IsVisible="{Binding IsUnlocked}"
                                                         HorizontalOptions="Center"
                                                         Spacing="8"
                                                         Margin="0,8,0,0">
                                        <Label Text="🏆"
                                               FontSize="20"
                                               VerticalOptions="Center"/>
                                        <Label Text="{Binding UnlockDateDisplay}"
                                               TextColor="#FFD700"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center">
                                            <Label.Shadow>
                                                <Shadow Brush="Black" Offset="0,2" Radius="10" Opacity="1.0"/>
                                            </Label.Shadow>
                                        </Label>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </Border>
                </Border>
            </Border>

            <!-- Share Button (outside the card, won't be in screenshot) -->
            <Button x:Name="ShareButton"
                   Grid.Row="1"
                   Text="📸  SHARE ACHIEVEMENT"
                   IsVisible="{Binding IsUnlocked}"
                   Command="{Binding ShareCommand}"
                   BackgroundColor="#FFD700"
                   TextColor="#1a237e"
                   FontAttributes="Bold"
                   FontSize="13"
                   CornerRadius="10"
                   HeightRequest="40"
                   Margin="0,10,0,0"
                   HorizontalOptions="Center"
                   WidthRequest="220"/>

            <!-- Your Collection Carousel -->
            <VerticalStackLayout Grid.Row="2" Spacing="6" Margin="0,8,0,10">
                <!-- Unlocked Count -->
                <Label Text="{Binding AchievementsCountText}"
                      TextColor="#FFD700"
                      FontSize="14"
                      FontAttributes="Bold"
                      HorizontalOptions="Center"/>

                <CollectionView ItemsSource="{Binding AchievementCollection}"
                               HeightRequest="80"
                               SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Horizontal" ItemSpacing="4"/>
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="viewmodels:AchievementThumbnail">
                            <Border WidthRequest="64"
                                   HeightRequest="64"
                                   StrokeShape="RoundRectangle 14"
                                   BackgroundColor="#1A1A3E"
                                   Padding="10"
                                   StrokeThickness="2"
                                   Stroke="Transparent"
                                   Opacity="{Binding IsUnlocked, Converter={StaticResource BoolToOpacityConverter}}">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border"
                                                Binding="{Binding IsSelected}"
                                                Value="True">
                                        <Setter Property="Stroke" Value="#FFD700"/>
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnCollectionItemTapped"
                                                         NumberOfTapsRequired="1"/>
                                </Border.GestureRecognizers>
                                <Image Source="{Binding Icon}"
                                      HeightRequest="36"
                                      WidthRequest="36"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center"/>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </Grid>
    </ScrollView>
</ContentPage>