<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="com.kizwiz.signwiz.Pages.SignDetailsPage"
             Style="{StaticResource AppPageStyle}"
             Title="Sign Review">

    <Grid Padding="20">
        <!-- Sign Video Card -->
        <Border StrokeThickness="2"
                Stroke="{DynamicResource Primary}"
                StrokeShape="RoundRectangle 24"
                BackgroundColor="{DynamicResource CardBackground}"
                Padding="24"
                Margin="0,10"
                VerticalOptions="Center"
                Shadow="{Shadow Brush=Black, Offset='4,6', Radius=20, Opacity=0.5}">

            <VerticalStackLayout Spacing="16">
                <!-- Sign Name -->
                <Label x:Name="SignNameLabel"
                       TextColor="{DynamicResource CardText}"
                       FontSize="28"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>

                <!-- Category -->
                <Label x:Name="CategoryLabel"
                       TextColor="{DynamicResource CardText}"
                       Opacity="0.7"
                       FontSize="16"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"/>

                <!-- Video Player -->
                <Grid HeightRequest="300"
                      HorizontalOptions="FillAndExpand"
                      BackgroundColor="Black">
                    <toolkit:MediaElement x:Name="SignVideo"
                                          ShouldAutoPlay="True"
                                          ShouldLoopPlayback="True"
                                          ShouldShowPlaybackControls="False"
                                          ShouldMute="True"
                                          Volume="0"
                                          Aspect="AspectFit"
                                          HorizontalOptions="FillAndExpand"
                                          VerticalOptions="FillAndExpand"
                                          ZIndex="999"
                                          MediaOpened="OnMediaOpened"
                                          MediaFailed="OnMediaFailed"/>
                </Grid>

                <!-- Replay Button -->
                <Button x:Name="ReplayButton"
                        Text="🔁  REPLAY"
                        Style="{StaticResource PrimaryButton}"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="16"
                        HeightRequest="48"
                        Clicked="OnReplayClicked"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
