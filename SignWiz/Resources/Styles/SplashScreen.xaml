<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="com.kizwiz.signwiz.Resources.Styles.SplashScreen">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#0e324d" Offset="0.0" />
            <GradientStop Color="#0d47a1" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid RowDefinitions="*,Auto,Auto,*">
        <Image Grid.Row="1"
               Source="logo_nobg.png"
               HeightRequest="220"
               Margin="40"/>

        <VerticalStackLayout Grid.Row="2" Spacing="0" HorizontalOptions="Center">
            <Label Text="SignWiz"
                   FontFamily="Bangers"
                   FontSize="54"
                   TextColor="White"
                   HorizontalOptions="Center">
                <Label.Shadow>
                    <Shadow Brush="Black"
                            Offset="4,4"
                            Radius="10"
                            Opacity="0.6"/>
                </Label.Shadow>
            </Label>

            <Label Text="The Magic of Signing"
                   FontSize="18"
                   TextColor="#FFA726"
                   HorizontalOptions="Center"
                   CharacterSpacing="2"
                   Margin="0,-5,0,0"/>
        </VerticalStackLayout>

        <ActivityIndicator Grid.Row="3"
                          IsRunning="True"
                          Color="#FFA726"
                          VerticalOptions="Center"
                          Scale="1.5"/>
    </Grid>
</ContentPage>