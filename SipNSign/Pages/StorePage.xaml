<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="com.kizwiz.sipnsign.Pages.StorePage"
             Title="StorePage">
    <ScrollView>
        <VerticalStackLayout>
            <Label Text="Unlock More Signs!" 
                   FontSize="24" 
                   FontAttributes="Bold"/>

            <CollectionView ItemsSource="{Binding AvailablePacks}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SignPackInfo">
                        <Border StrokeShape="RoundRectangle 10">
                            <Grid RowDefinitions="Auto,Auto,Auto" Padding="15">
                                <Label Text="{Binding Name}" 
                                       FontSize="20" 
                                       FontAttributes="Bold"/>
                                <Label Text="{Binding Description}" 
                                       Grid.Row="1"/>
                                <Button Text="{Binding Price, StringFormat='Unlock for £{0}'}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodels:StoreViewModel}}, Path=PurchaseCommand}"
                                        CommandParameter="{Binding Id}"
                                        IsEnabled="{Binding IsUnlocked, Converter={StaticResource InverseBoolConverter}}"
                                        Grid.Row="2"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Text="Restore Purchases" 
                    Command="{Binding RestoreCommand}"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>